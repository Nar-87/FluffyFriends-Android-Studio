<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgFondoDetalle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_app"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloDetalle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/detalle_servicio"
        android:layout_marginTop="32dp"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#E44F45"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card Servicio -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardServicio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvTituloDetalle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTipoServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tipo_servicio"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/tvDescripcionServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/descripcion_servicio"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvPrecioServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/precio_servicio"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvFechaServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/formato_fecha"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:textColor="#666666"/>

            <TextView
                android:id="@+id/tvEstadoServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/estado_activo"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:textStyle="bold"
                android:textColor="#388E3C"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Botón Editar -->
    <Button
        android:id="@+id/btnEditarServicio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_editar_servicio"
        android:layout_marginTop="24dp"
        android:backgroundTint="#FFA000"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/cardServicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón cancelar -->
    <Button
        android:id="@+id/btnCancelarServicio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_cancelar_servicio"
        android:layout_marginTop="12dp"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btnEditarServicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
