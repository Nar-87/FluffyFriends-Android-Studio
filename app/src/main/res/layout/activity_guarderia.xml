<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo -->
    <ImageView
        android:id="@+id/imgFondoGuarderia"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_app"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloGuarderia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/guarderia"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#E44F45"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Mascota -->
    <TextView
        android:id="@+id/tvMascotaG"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/nombremascota"
        android:textSize="18sp"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloGuarderia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card central -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardGuarderia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="10dp"
        android:backgroundTint="#88FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvMascotaG"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tipo -->
            <TextView
                android:text="@string/tipos_guarderia"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/rgTipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbDiaria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guarderia_diaria"
                    android:textSize="18sp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbNocturna"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guarderia_nocturna"
                    android:textSize="18sp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbPremium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guarderia_premium"
                    android:textSize="18sp"/>
            </RadioGroup>

            <!-- Duración -->
            <TextView
                android:text="@string/duracion"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/rgDuracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb1Dia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/un_dia"
                    android:textSize="18sp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb3Dias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tres_dias"
                    android:textSize="18sp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb1Semana"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/una_semana"
                    android:textSize="18sp"/>
            </RadioGroup>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"/>

            <!-- Total -->
            <TextView
                android:id="@+id/tvTotal"
                android:text="@string/total_coste_guarderia"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#E44F45"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón confirmar -->
    <Button
        android:id="@+id/btnConfirmar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/confirmar_serv_guarderia"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E44F45"
        android:layout_margin="16dp"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/cardGuarderia"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintVertical_bias="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Menú inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:menu="@menu/menu_inferior"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
