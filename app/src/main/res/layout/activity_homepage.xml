<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Card homepage -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardHomePage"
        android:layout_width="0dp"
        android:layout_height="230dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#D8E7D0"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSaludoHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/saludo_usuario"
                android:textColor="#E44F45"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="@string/subtitulo_perfil"
                android:textColor="#666666"
                android:textSize="28sp" />

            <LinearLayout
                android:id="@+id/layoutPerfilHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/imgIconoPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvEditarPerfilHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/edit_perfil"
                    android:textColor="#E44F45"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Fondo + cards -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBloqueInferior"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardHomePage"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Imagen de fondo -->
            <ImageView
                android:id="@+id/imgFondoHome2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/fondo_homepage" />

            <!-- Contenedor de tarjetas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <!-- Registrar mascota -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRegistrarMascota"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginBottom="14dp"
                    android:backgroundTint="#88FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_add"
                            app:tint="#E44F45" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:gravity="center|start"
                            android:text="@string/registrar_mascota"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Mis mascotas -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMisMascotas"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginBottom="14dp"
                    android:backgroundTint="#88FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/imgMisMascotas"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_paw"
                            app:tint="#E44F45"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:gravity="center|start"
                            android:text="@string/mascotas"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Mi cuenta -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMiCuenta"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginBottom="14dp"
                    android:backgroundTint="#88FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_profile"
                            app:tint="#E44F45"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:gravity="center|start"
                            android:text="@string/mi_cuenta_home"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Soporte -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardInfoSoporte"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:backgroundTint="#88FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_info"
                            app:tint="#E44F45"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:gravity="center|start"
                            android:text="@string/info"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Menú inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:menu="@menu/menu_inferior"
        android:background="#FFFFFF"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>