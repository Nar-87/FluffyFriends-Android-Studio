<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo -->
    <ImageView
        android:id="@+id/imgFondoPeluqueria"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_app"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloPeluqueria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/peluqueria"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#E44F45"
        android:gravity="center"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Mascota seleccionada -->
    <TextView
        android:id="@+id/tvMascotaPeluqueria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/peluqueria_mascota"
        android:textSize="18sp"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPeluqueria"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card central -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPeluqueria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:backgroundTint="#88FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvMascotaPeluqueria"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tipo de servicio -->
            <TextView
                android:id="@+id/tvTipoServicio"
                android:text="@string/tipo_peluqueria"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/rgTipoPeluqueria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbCorteBasico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pelu_corte_basico"
                    android:textSize="20sp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbBanoSecado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pelu_banio_secado"
                    android:textSize="20sp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbPremium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pelu_servicio_premium"
                    android:textSize="20sp"/>
            </RadioGroup>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"/>

            <!-- Total -->
            <TextView
                android:id="@+id/tvTotalPeluqueria"
                android:text="@string/pelu_total"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#E44F45"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón continuar -->
    <Button
        android:id="@+id/btnConfirmarPeluqueria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:text="@string/confirmar_serv_pelu"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:layout_margin="16dp"
        android:backgroundTint="#E44F45"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/cardPeluqueria"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintVertical_bias="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Menú inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:menu="@menu/menu_inferior"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
