<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo -->
    <ImageView
        android:id="@+id/imgFondoRegMascota"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/fondo_app"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Contenido -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/headerContainerMascota"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvTituloRegistrarMascota"
                    android:text="@string/reg_mascotas"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#E44F45"
                    android:layout_marginBottom="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="@string/datos_mascota"
                    android:textSize="24sp"
                    android:textColor="#666"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/imgIconoUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvCambiarFotoMascota"
                    android:text="@string/editfoto_mascota"
                    android:textColor="#E44F45"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Card formulario -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#CCFFFFFF">

                <LinearLayout
                    android:id="@+id/formContainer"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Nombre -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="#E44F45">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtNombreMascota"
                            android:hint="@string/nombre_mascota"
                            android:textSize="22sp"
                            android:padding="14dp"
                            android:textColor="#333"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tipo -->
                    <TextView
                        android:text="@string/tipo_registro_mascota"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#E44F45"
                        android:layout_marginBottom="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        android:backgroundTint="#88FFFFFF"
                        android:layout_marginBottom="12dp">

                        <Spinner
                            android:id="@+id/spinnerTipoMascota"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Raza -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="#E44F45">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtRazaMascota"
                            android:hint="@string/raza_mascota"
                            android:padding="14dp"
                            android:textSize="22sp"
                            android:textColor="#333"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Sexo -->
                    <TextView
                        android:text="@string/sexo_mascota"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#E44F45"
                        android:layout_marginBottom="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        android:backgroundTint="#88FFFFFF"
                        android:layout_marginBottom="12dp">

                        <Spinner
                            android:id="@+id/spinnerSexoMascota"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Color -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="#E44F45">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtColorMascota"
                            android:hint="@string/color_mascota"
                            android:padding="14dp"
                            android:textColor="#333"
                            android:textSize="22sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Descripción -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="#E44F45">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtDescripcionMascota"
                            android:hint="@string/descipcion_mascota"
                            android:maxLines="2"
                            android:padding="14dp"
                            android:textSize="22sp"
                            android:textColor="#333"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Observaciones -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="#E44F45">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtObservacionesMascota"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/observaciones"
                            android:textSize="22sp"
                            android:maxLines="3"
                            android:padding="14dp"
                            android:textColor="#333" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Registrar mascota -->
            <Button
                android:id="@+id/btnRegistrarMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btnregistro_mascota"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E44F45"
                android:layout_marginTop="20dp"
                android:padding="14dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Menú inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:menu="@menu/menu_inferior"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
