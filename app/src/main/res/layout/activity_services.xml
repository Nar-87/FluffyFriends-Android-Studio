<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo -->
    <ImageView
        android:id="@+id/imgFondoServicios"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_servicios"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Contenido -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Título -->
            <TextView
                android:id="@+id/tvTituloServicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="@string/servicio_dispo"
                android:textColor="#E44F45"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Comunidad -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardComunidadMascotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#EEFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvComunidadMascotas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/adopta_mascota"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#333"/>

                        <TextView
                            android:id="@+id/tvConoceAnimales"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/adopta_mascota_hogar"
                            android:textSize="18sp"
                            android:textColor="#666"
                            android:layout_marginTop="6dp"/>

                        <Button
                            android:id="@+id/btnUnirseComunidad"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/ir_comunidad"
                            android:textSize="20sp"
                            android:backgroundTint="#E44F45"
                            android:textColor="#FFFFFF"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="150dp"
                        android:src="@drawable/dog_image"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvSubServicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/subtitulo_servicios"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#E44F45"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"/>

            <!-- SERVICIOS -->
            <!-- card guardería -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGuarderia"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#88FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_guarderia"
                        app:tint="#E44F45"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:gravity="start"
                        android:text="@string/guarderia"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- card peluqiería -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPeluqueria"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#88FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_peluqueria"
                        app:tint="#E44F45"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="start"
                        android:layout_marginStart="16dp"
                        android:text="@string/peluqueria"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- card veterinario -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVeterinario"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#88FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_veterinario"
                        app:tint="#E44F45"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="start"
                        android:layout_marginStart="16dp"
                        android:text="@string/veterinario"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- card adiestramiento -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAdiestramiento"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#88FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_adiestramiento"
                        app:tint="#E44F45"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="start"
                        android:layout_marginStart="16dp"
                        android:text="@string/adiestramiento"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- card paseos -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPaseos"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#88FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_paseos"
                        app:tint="#E44F45"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="start"
                        android:layout_marginStart="16dp"
                        android:text="@string/paseos"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- card antipulgas -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAntipulgas"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#88FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_antipulgas"
                        app:tint="#E44F45"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="start"
                        android:layout_marginStart="16dp"
                        android:text="@string/antipulgas"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Menú inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:menu="@menu/menu_inferior"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
