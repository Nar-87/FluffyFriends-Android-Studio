<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo -->
    <ImageView
        android:id="@+id/imgFondoVeterinario"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_app"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloVeterinario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/veterinario"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#E44F45"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Mascota -->
    <TextView
        android:id="@+id/tvMascotaVeterinario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/veterinario_mascota"
        android:textSize="18sp"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloVeterinario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card central -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardVeterinario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:backgroundTint="#88FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvMascotaVeterinario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvTipoConsulta"
                android:text="@string/tipo_consulta_veterinario"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/rgTipoVeterinario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbConsulta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/consulta_general_veterinario"
                    android:textSize="20sp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbVacunacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vacunacion"
                    android:textSize="20sp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbDesparasitacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/desparasitacion"
                    android:textSize="20sp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbRevision"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/revision_veterinario"
                    android:textSize="20sp" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvTotalVeterinario"
                android:text="@string/total_veterinario"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#E44F45"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón confirmar -->
    <Button
        android:id="@+id/btnConfirmarVeterinario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#E44F45"
        android:padding="14dp"
        android:text="@string/confirmar_veterinario"
        android:textColor="#FFFFFF"
        android:layout_margin="16dp"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/cardVeterinario"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintVertical_bias="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Menú inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:menu="@menu/menu_inferior"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
